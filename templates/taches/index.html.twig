{% extends 'base.html.twig' %}

{% block title %}Liste des tâches{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="m-0">📋 Tâches (depuis la base)</h1>
        <a href="{{ path('app_tache_ajouter') }}" class="btn btn-primary">➕ Ajouter</a>
    </div>

    {% if taches is empty %}
        <div class="alert alert-info">
            Aucune tâche en base de données.
            <a href="{{ path('app_tache_ajouter') }}" class="alert-link">Créer une tâche</a>
        </div>
    {% else %}
        <ul class="list-group">
            {% set taches_triees = taches|sort((a, b) => b.terminee <=> a.terminee) %}
            {% for tache in taches_triees %}
                <li class="list-group-item d-flex justify-content-between align-items-center {% if tache.terminee %}text-muted{% endif %}" style="{% if tache.terminee %}text-decoration: line-through;{% endif %}">
                    <span>
                        <strong>{{ tache.titre }}</strong>
                    </span>
                    <span class="d-flex align-items-center gap-2">
                        <a href="{{ path('app_tache_detail', {'id': tache.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                        {% if not tache.terminee %}
                            <a href="{{ path('app_tache_terminer', {'id': tache.id}) }}" class="btn btn-sm btn-outline-success">✅ Terminer</a>
                        {% endif %}
                        {% if tache.terminee %}
                            <span class="badge bg-success">Terminée</span>
                        {% else %}
                            <span class="badge bg-warning text-dark">En cours</span>
                        {% endif %}
                    </span>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
